{
  "name": "Java 22 + Maven",
  "image": "eclipse-temurin:22-jdk",
  "postCreateCommand": "apt-get update && apt-get install -y maven git && java -version && mvn -version",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven"
      ],
      "settings": {
        "java.home": "/opt/java/openjdk"
      }
    }
  },
  "forwardPorts": [8080]
  
}